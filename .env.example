# GEMINI_API_KEY: Optional server-side Gemini API key.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# OPENAI_API_KEY: Optional OpenAI-compatible API key for server-side extraction.
OPENAI_API_KEY="MY_OPENAI_API_KEY"
OPENAI_BASE_URL="https://api.openai.com/v1"

# VENICE_API_KEY: Optional Venice fallback provider for extraction tasks.
VENICE_API_KEY="MY_VENICE_API_KEY"

# VITE_NEXUS_API_BASE_URL: Optional absolute URL for a separately deployed
# Nexus backend (for example, a Render Web Service). Leave blank when the UI and
# Express API are served from the same origin.
VITE_NEXUS_API_BASE_URL=""

# VITE_GOOGLE_CLIENT_ID: Your Google OAuth Client ID.
# VITE_GOOGLE_API_KEY: Your Google Picker API Key.
VITE_GOOGLE_CLIENT_ID="MY_CLIENT_ID"
VITE_GOOGLE_API_KEY="MY_API_KEY"
